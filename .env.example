# n8n roster webhook (optional). See README.
# VITE_N8N_ROSTER_WEBHOOK=https://your-instance.app.n8n.cloud/webhook/...

# Supabase Auth — when BOTH are set, the app requires email/password sign-in before the roster.
# Dashboard: https://supabase.com/dashboard → Settings → API → copy Project URL + Publishable key.
# https://supabase.com/docs/guides/api/api-keys
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Emergency only — skip login while Supabase email is rate-limited (local `.env.local`). Never for public prod.
# VITE_BYPASS_AUTH=true

# Readme screenshots only
# VITE_SCREENGRAB_PRIVACY=true
